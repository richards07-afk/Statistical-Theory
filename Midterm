        "def mean(x):\n",
        "    return sum(x)/len(x)\n",
        "\n",
        "def variance(x):\n",
        "    m = mean(x)\n",
        "    return sum((i-m)**2 for i in x)/(len(x)-1)\n",
        "\n",
        "def std(x):\n",
        "    return variance(x)**0.5\n",
        "\n",
        "def median(x):\n",
        "    s = sorted(x)\n",
        "    n = len(s)\n",
        "    if n%2==0:\n",
        "        return (s[n//2-1]+s[n//2])/2\n",
        "    return s[n//2]\n",
        "\n",
        "def quartiles(x):\n",
        "    s = sorted(x)\n",
        "    n = len(s)\n",
        "    q2 = median(s)\n",
        "    q1 = median(s[:n//2])\n",
        "    q3 = median(s[n//2:])\n",
        "    return q1,q2,q3\n",
        "\n",
        "def deciles(x):\n",
        "    s = sorted(x)\n",
        "    n = len(s)\n",
        "    d = []\n",
        "    for i in range(1,10):\n",
        "        k = i*(n+1)/10\n",
        "        f = int(k)\n",
        "        c = min(f+1,n)\n",
        "        if f==0:\n",
        "            val=s[0]\n",
        "        else:\n",
        "            val = s[f-1] + (k-f)*(s[c-1]-s[f-1])\n",
        "        d.append(val)\n",
        "    return d\n",
        "\n",
        "def skewness(x):\n",
        "    m = mean(x)\n",
        "    sd = std(x)\n",
        "    n=len(x)\n",
        "    return sum((i-m)**3 for i in x)/(n*sd**3)\n",
        "\n",
        "def kurtosis(x):\n",
        "    m=mean(x)\n",
        "    sd=std(x)\n",
        "    n=len(x)\n",
        "    return sum((i-m)**4 for i in x)/(n*sd**4)-3\n",
